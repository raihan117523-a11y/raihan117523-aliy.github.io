<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flipkart - Women Clothing</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f5f5f5;
}

/* Header */
header {
    background: #2874f0;
    color: white;
    padding: 15px;
    text-align: center;
}

/* Navigation */
nav {
    background: #ff9f00;
    padding: 10px;
    text-align: center;
}

nav a {
    color: black;
    margin: 15px;
    text-decoration: none;
    font-weight: bold;
}

/* Hero Section */
.hero {
    background: url('https://images.unsplash.com/photo-1495121605193-b116b5b09a0c') no-repeat center/cover;
    height: 300px;
    display: flex;
    justify-content: center;
    align-items: center;
    color: white;
    font-size: 32px;
    font-weight: bold;
}

/* Products */
.products {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    padding: 20px;
}

.card {
    background: white;
    padding: 15px;
    border-radius: 10px;
    text-align: center;
    box-shadow: 0 3px 8px rgba(0,0,0,0.2);
}

.card img {
    width: 100%;
    border-radius: 10px;
}

.card h3 {
    margin: 10px 0;
}

.price {
    color: #2874f0;
    font-weight: bold;
}

/* Button */
button {
    padding: 10px;
    background: #ff9f00;
    border: none;
    cursor: pointer;
    border-radius: 5px;
}

/* Footer */
footer {
    background: #111;
    color: white;
    text-align: center;
    padding: 20px;
}
</style>

</head>

<body>

<header>
    <h1>Flipkart</h1>
    <p>Women Clothing Collection</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">Shop</a>
    <a href="#">Contact</a>
</nav>

<div class="hero">
    Latest Fashion for Women
</div>

<section class="products">

    <div class="card">
        <img src="https://images.unsplash.com/photo-1520975922203-b1c0b2caa95c">
        <h3>Casual Top</h3>
        <p class="price">$20</p>
        <button>Buy Now</button>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1519741497674-611481863552">
        <h3>Summer Dress</h3>
        <p class="price">$35</p>
        <button>Buy Now</button>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1521572267360-ee0c2909d518">
        <h3>Stylish Jacket</h3>
        <p class="price">$50</p>
        <button>Buy Now</button>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1495121605193-b116b5b09a0c">
        <h3>Floral Dress</h3>
        <p class="price">$28</p>
        <button>Buy Now</button>
    </div>

</section>

<footer>
    <p>Flipkart Women Clothing Store</p>
    <p>Address: 175 1, Soukya Rd, Bengaluru, Karnataka 560067, India</p>
    <p>Phone: +91 4445614700</p>
</footer>

</body>
</html>
